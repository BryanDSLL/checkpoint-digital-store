# URL do Backend (Express)
VITE_API_URL=http://localhost:3001

# ─── Backend ───────────────────────────────────────────
# Neon PostgreSQL (substitua pelos seus dados)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Caso use variáveis separadas
PGHOST=ep-seu-host.neon.tech
PGUSER=neondb_owner
PGPASSWORD=sua_senha_aqui
PGDATABASE=neondb
PGPORT=5432

# JWT para autenticação do admin
JWT_SECRET=gamestore-mude-em-producao-use-string-aleatoria-longa

# Porta do servidor Express (opcional, padrão 3001)
PORT=3001
